# OS / editor junk
.DS_Store
Thumbs.db
*.log
.claude/

# Flutter / Dart build output (regenerated by CI)
deemusiq-app/build/
deemusiq-app/.dart_tool/
deemusiq-app/.flutter-plugins
deemusiq-app/.flutter-plugins-dependencies
deemusiq-app/android/.gradle/
deemusiq-app/**/Pods/

# Backend lives in its own private repo: https://github.com/s-b-repo/deemusiq-backend
# The local backend/ checkout is a nested git repo — keep it out of this one.
backend/

# Node — anywhere in the tree
node_modules/
dist/
npm-debug.log*
yarn-error.log*

# Secrets — never commit signing keys or env files
*.jks
*.keystore
key.properties
.env
.env.*
!.env.example
*.env
